<?xml version="1.0"?>
<ruleset name="Custom WordPress PHPMD Ruleset"
         xmlns="http://pmd.sf.net/ruleset/1.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://pmd.sf.net/ruleset/1.0.0 http://pmd.sf.net/ruleset_xml_schema.xsd"
         xsi:noNamespaceSchemaLocation="http://pmd.sf.net/ruleset_xml_schema.xsd">

    <description>
        Custom PHPMD ruleset tailored for WordPress plugin development.
        Adjusted to respect WordPress coding conventions while maintaining code quality.
    </description>

    <!-- Clean Code Rules -->
    <rule ref="rulesets/cleancode.xml">
        <!-- WordPress uses global functions extensively, so exclude this -->
        <exclude name="StaticAccess"/>
    </rule>

    <!-- Code Size Rules -->
    <rule ref="rulesets/codesize.xml">
        <!-- WordPress admin classes can be large, so exclude this -->
        <exclude name="TooManyFields"/>
    </rule>
    <rule ref="rulesets/codesize.xml/CyclomaticComplexity">
        <properties>
            <property name="reportLevel" value="15"/>
        </properties>
    </rule>
    <rule ref="rulesets/codesize.xml/NPathComplexity">
        <properties>
            <property name="minimum" value="250"/>
        </properties>
    </rule>
    <rule ref="rulesets/codesize.xml/ExcessiveMethodLength">
        <properties>
            <property name="minimum" value="120"/>
        </properties>
    </rule>
    <rule ref="rulesets/codesize.xml/ExcessiveClassLength">
        <properties>
            <property name="minimum" value="800"/>
        </properties>
    </rule>
    <rule ref="rulesets/codesize.xml/ExcessiveParameterList">
        <properties>
            <property name="minimum" value="8"/>
        </properties>
    </rule>
    <rule ref="rulesets/codesize.xml/ExcessivePublicCount">
        <properties>
            <property name="minimum" value="30"/>
        </properties>
    </rule>
    <rule ref="rulesets/codesize.xml/TooManyMethods">
        <properties>
            <property name="maxmethods" value="20"/>
        </properties>
    </rule>

    <!-- Controversial Rules -->
    <rule ref="rulesets/controversial.xml">
        <!-- WordPress uses snake_case for method names, not camelCase -->
        <exclude name="CamelCaseMethodName"/>
        <!-- WordPress uses snake_case for property names -->
        <exclude name="CamelCasePropertyName"/>
        <!-- WordPress uses snake_case for parameter names -->
        <exclude name="CamelCaseParameterName"/>
        <!-- WordPress uses snake_case for variable names -->
        <exclude name="CamelCaseVariableName"/>
    </rule>

    <!-- Design Rules -->
    <rule ref="rulesets/design.xml">
        <!-- Allow private/final static methods for utility classes -->
        <exclude name="EmptyCatchBlock"/>
    </rule>
    <rule ref="rulesets/design.xml/NumberOfChildren">
        <properties>
            <property name="minimum" value="20"/>
        </properties>
    </rule>
    <rule ref="rulesets/design.xml/DepthOfInheritance">
        <properties>
            <property name="maximum" value="6"/>
        </properties>
    </rule>
    <rule ref="rulesets/design.xml/CouplingBetweenObjects">
        <properties>
            <property name="maximum" value="15"/>
        </properties>
    </rule>

    <!-- Naming Rules -->
    <rule ref="rulesets/naming.xml">
        <!-- WordPress uses short names for hooks and callbacks -->
        <exclude name="ShortMethodName"/>
        <!-- Adjusted below -->
        <exclude name="ShortVariable"/>
        <!-- WordPress uses underscores, not camelCase -->
        <exclude name="ConstantNamingConventions"/>
    </rule>
    <rule ref="rulesets/naming.xml/ShortVariable">
        <properties>
            <property name="minimum" value="2"/>
            <property name="exceptions" value="id,q,w,i,j,k,v,e,fn,wp,db,ok,ex"/>
        </properties>
    </rule>
    <rule ref="rulesets/naming.xml/LongVariable">
        <properties>
            <property name="maximum" value="30"/>
        </properties>
    </rule>
    <rule ref="rulesets/naming.xml/ShortMethodName">
        <properties>
            <property name="minimum" value="2"/>
            <property name="exceptions" value="up,to,go,do,run,wp"/>
        </properties>
    </rule>
    <rule ref="rulesets/naming.xml/BooleanGetMethodName">
        <properties>
            <property name="checkParameterizedMethods" value="true"/>
        </properties>
    </rule>

    <!-- Unused Code Rules -->
    <rule ref="rulesets/unusedcode.xml">
        <!-- Allow unused parameters for hook callbacks and inheritance -->
        <exclude name="UnusedFormalParameter"/>
    </rule>

</ruleset>
