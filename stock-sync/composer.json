{
    "name": "stock-sync/stock-sync",
    "description": "Automate WooCommerce product availability updates from distributor price lists.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": "^8.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^11",
        "mockery/mockery": "^1.6",
        "brain/monkey": "^2.6",
        "squizlabs/php_codesniffer": "^3.9"
    },
    "autoload": {
        "classmap": [
            "includes/",
            "includes/distributors/",
            "includes/interfaces/",
            "includes/adapters/"
        ]
    },
    "autoload-dev": {
        "classmap": [
            "tests/"
        ]
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "phpcs": "vendor/bin/phpcs"
    }
}
